# 로컬 환경 변수 및 민감 정보
.env
.env.*
!.env.example

# Python 가상 환경
.venv/
venv/
env/

# Python 캐시 및 테스트 캐시
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# 로컬 에디터 및 OS 생성 파일
.idea/
.vscode/
.DS_Store
Thumbs.db

# 로컬에서 생성되는 실행 결과 리포트
reports/*
**/screenshots/
!reports/.gitkeep
!reports/**/
!reports/**/.gitkeep
**/reports/*
!**/reports/.gitkeep
!**/reports/**/
!**/reports/**/.gitkeep

# 로컬 API 응답 캡처 스크립트
part1_api_automation/capture_016_018.py
part1_api_automation/capture_responses.py
part1_api_automation/capture_teacher_doc.py

